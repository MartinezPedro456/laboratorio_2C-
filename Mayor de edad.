#include <iostream>

int main() {
    int edad;

    std::cout << "Ingresa tu edad: ";
    std::cin >> edad;

    // Estructura de decisión if/else
    if (edad >= 18) {
        std::cout << "Eres mayor de edad. ¡Bienvenido al club de los adultos!" << std::endl;
    } else {
        std::cout << "Eres menor de edad. ¡Disfruta tu juventud!" << std::endl;
    }

    return 0;
}
