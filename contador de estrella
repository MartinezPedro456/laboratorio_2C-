#include <iostream>

int main() {
    int cantidad;

    std::cout << "¿Cuántas estrellas quieres ver brillar hoy?: ";
    std::cin >> cantidad;

    std::cout << "Cielo nocturno: ";
    for (int i = 0; i < cantidad; i++) {
        std::cout << "* "; // Imprime una estrella en cada vuelta del bucle
    }
    
    std::cout << "\n¡Es un cielo hermoso!" << std::endl;
    return 0;
}
